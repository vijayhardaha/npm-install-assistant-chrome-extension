# =======================================================================
# Stylelint Ignore
# =======================================================================
# Purpose: Defines the files and directories that the Stylelint engine
#          should skip to prevent linting build artifacts, external
#          libraries, or generated CSS.
# Docs:    https://stylelint.io/user-guide/ignore
# =======================================================================

# ----------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------
# Packages ship CSS (Bootstrap, Tailwind, WP plugins/themes).
node_modules/
vendor/

# ----------------------------------------------------------------------
# Build & Compilation Output
# ----------------------------------------------------------------------
# Next.js generates CSS chunks; SvelteKit generates component CSS;
# bundlers emit compiled stylesheets.
.next/
.svelte-kit/
build/
dist/
out/

# ----------------------------------------------------------------------
# Cache Directories
# ----------------------------------------------------------------------
# Build tool caches that may contain transformed CSS.
.cache/
.eslintcache
.stylelintcache
.turbo/
.vite/

# ----------------------------------------------------------------------
# Coverage & Reports
# ----------------------------------------------------------------------
# Istanbul and Playwright generate HTML reports with inline CSS.
coverage/
playwright-report/

# ----------------------------------------------------------------------
# Public & Static Assets
# ----------------------------------------------------------------------
# Committed CSS assets, vendor stylesheets, theme CSS (WordPress).
public/
assets/
static/

# ----------------------------------------------------------------------
# Deployment Config
# ----------------------------------------------------------------------
# Platform config dirs — safe to skip, no CSS worth linting.
.netlify/
.vercel/
.wrangler/

# ----------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------
.tmp/
tmp/

# ----------------------------------------------------------------------
# Minified & Generated
# ----------------------------------------------------------------------
# Never lint minified or pre-compiled stylesheets.
*.min.css
*.min.map
