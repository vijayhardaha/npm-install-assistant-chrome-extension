{
  "name": "npm-install-assistant-chrome-extension",
  "version": "0.0.2",
  "private": true,
  "description": "Chrome extension that adds a React-powered install assistant block to npm package sidebars.",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs .",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md,yml}\"",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint --fix \"src/**/*.{css,scss}\"",
    "tsc": "tsc --noEmit",
    "link": "rm -rf ~/.xoxo/npm-assistant && mkdir -p ~/.xoxo && ln -sf $PWD ~/.xoxo/npm-assistant",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vijayhardaha/dev-config": "^1.0.8",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.59.0",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-property-sort-order-smacss": "^11.2.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-static-copy": "^3.3.0",
    "vitest": "^4.1.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
