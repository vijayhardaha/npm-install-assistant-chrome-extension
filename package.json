{
	"name": "npm-install-assistant-chrome-extension",
	"version": "0.0.1",
	"private": true,
	"description": "Chrome extension that adds a React-powered install assistant block to npm package sidebars.",
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
		"lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
		"format": "prettier \"**/*.{js,jsx,ts,tsx,css,md,json,html}\" --write",
		"format:check": "prettier \"**/*.{js,jsx,ts,tsx,css,md,json,html}\" --check",
		"stylelint": "stylelint \"src/**/*.{css,scss}\"",
		"stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
		"tsc": "tsc --noEmit",
		"pack:ext": "bun run lint && bun run format:check && bun run stylelint && bun run build && bun run test && mkdir -p ~/chrome-extensions && rm -rf ~/chrome-extensions/npm-install-assistant && cp -R dist ~/chrome-extensions/npm-install-assistant",
		"prepare": "husky"
	},
	"type": "module",
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.39.3",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/chrome": "^0.1.37",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.0",
		"prettier": "^3.8.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rollup": "^4.59.0",
		"sass": "^1.97.3",
		"stylelint": "^17.4.0",
		"stylelint-config-property-sort-order-smacss": "^11.1.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^8.0.1",
		"vite-plugin-static-copy": "^3.3.0",
		"vitest": "^4.1.0"
	}
}
